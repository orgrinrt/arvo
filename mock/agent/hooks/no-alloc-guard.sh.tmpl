#!/usr/bin/env bash
# @matchers: Write, Edit
# @timeout: 5
# Agent hook: block `use alloc::`, `Vec`, `String`, `Box` in arvo crates.
#
# arvo does not allocate. Use `[T; N]` or a consumer-owned buffer.
# The build-time `no-alloc-enforcer` lint backstops this hook.

set -uo pipefail

__INPUT=$(cat)

{{HOOK_HELPERS}}

FILE_PATH=$(_extract file_path)
COMMAND=""
_scope_or_allow

TARGET="$FILE_PATH"
CONTENT=$(_extract new_string)
if [[ -z "$CONTENT" ]]; then
    CONTENT=$(_extract content)
fi

if ! echo "$TARGET" | grep -qE "mock/crates/arvo[^/]*/src/"; then
    allow
fi

if echo "$CONTENT" | grep -qE "^[[:space:]]*(pub[[:space:]]+)?use[[:space:]]+alloc::"; then
    deny "arvo is no-alloc; \`use alloc::\` is forbidden. Use const-generic arrays \`[T; N]\` or take a consumer-owned buffer by reference."
fi

if echo "$CONTENT" | grep -qE "^[[:space:]]*extern[[:space:]]+crate[[:space:]]+alloc"; then
    deny "arvo is no-alloc; \`extern crate alloc\` is forbidden."
fi

if echo "$CONTENT" | grep -qE "(^|[^a-zA-Z0-9_])Vec<"; then
    deny "arvo is no-alloc; \`Vec<T>\` is forbidden. Use \`[T; N]\` with a const-generic capacity, or \`&mut [T]\` passed in by the consumer."
fi

if echo "$CONTENT" | grep -qE "(^|[^a-zA-Z0-9_])String([^a-zA-Z0-9_]|$)"; then
    deny "arvo is no-alloc; \`String\` is forbidden. Use \`&str\` or a const-generic \`[u8; N]\` buffer."
fi

if echo "$CONTENT" | grep -qE "(^|[^a-zA-Z0-9_])Box<"; then
    deny "arvo is no-alloc; \`Box<T>\` is forbidden. Store by value or hand the consumer a reference."
fi

# --- bare Option / Result in pub signatures (task #77) ----------------------
# Conservative line match: `pub fn ... -> Option<` / `Result<` or
# `pub fn ... : Option<`/`Result<` in param lists. Skips lines carrying
# `// allow-bare-option:` / `// allow-bare-result:` (with tracked task id).
#
# Std trait impls whose signatures are fixed by the language are not caught
# here — they live inside `impl X for Y` blocks whose individual method
# lines don't carry `pub`. Agents can still escape with an explicit allow
# comment when necessary.

if echo "$CONTENT" | grep -qE "^\s*pub\s+fn\s+.*\sOption<" | grep -qvE "allow-bare-option:"; then
    deny "arvo: bare \`Option<T>\` in a \`pub\` signature. Use \`notko::Maybe<T>\`. If this is a std-trait-impl method, remove the \`pub\` qualifier or add \`// allow-bare-option: tracked: #<task-id>\`."
fi

if echo "$CONTENT" | grep -qE "^\s*pub\s+fn\s+.*\sResult<" | grep -qvE "allow-bare-result:"; then
    deny "arvo: bare \`Result<T, E>\` in a \`pub\` signature. Use \`notko::Outcome<T, E>\`. If this is a std-trait-impl method (fmt::Result, etc.), remove the \`pub\` qualifier or add \`// allow-bare-result: tracked: #<task-id>\`."
fi

allow
