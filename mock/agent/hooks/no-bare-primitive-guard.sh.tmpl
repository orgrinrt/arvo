#!/usr/bin/env bash
# @matchers: Write, Edit
# @timeout: 5
# Agent hook: block bare primitive identifiers anywhere in arvo
# crate source.
#
# The rule: `u8..u128`, `i8..i128`, `f32`, `f64`, `usize`, `isize`,
# `bool`, `Option`, `Result`, `String`, and non-static `&str` do not
# exist in arvo. Not in public fn sigs, not in private fields, not in
# `let` bindings, not in cast expressions (`as u32`), not in literal
# suffixes (`0u32`), not in tuple-struct fields, not in trait method
# parameter types. Wrap through arvo types (`UFixed` / `IFixed` /
# `FastFloat` / `StrictFloat` / `USize` / `Cap` / `Bool` /
# `ContentHash` / ...) or notko's `Maybe` / `Outcome` / `Just`.
#
# Escape hatch: `// lint:allow(<rule>) reason: ...; tracked: #N` on
# the offending line. The rule name matches the violation
# (no-bare-numeric / no-bare-option / no-bare-result / no-bare-string
# / no-public-raw-field / arvo-types-only).
#
# The build-time lint pack (mockspace-hilavitkutin-stack-lints)
# backstops this hook with the same coverage.

set -uo pipefail

__INPUT=$(cat)

{{HOOK_HELPERS}}

FILE_PATH=$(_extract file_path)
COMMAND=""
_scope_or_allow

TARGET="$FILE_PATH"
CONTENT=$(_extract new_string)
if [[ -z "$CONTENT" ]]; then
    CONTENT=$(_extract content)
fi

if ! echo "$TARGET" | grep -qE "mock/crates/arvo[^/]*/src/"; then
    allow
fi

# Examine the edit line-by-line. A line is exempt if it contains
# `lint:allow(<some-rule>)` OR is a `//` comment. Empty content means
# nothing to check.
if [[ -z "$CONTENT" ]]; then
    allow
fi

# Primitive tokens we block. Word-boundary matches via grep -w.
BARE_NUMS='u8|u16|u32|u64|u128|i8|i16|i32|i64|i128|f32|f64|usize|isize|bool'

while IFS= read -r LINE; do
    # Skip empty, skip comments, skip lines with an explicit allow.
    case "$LINE" in
        '' ) continue ;;
        *'lint:allow('* ) continue ;;
    esac
    TRIMMED=$(printf '%s' "$LINE" | sed -e 's/^[[:space:]]*//')
    case "$TRIMMED" in
        '//'* ) continue ;;
    esac

    # Strip simple string literals and char literals from the line so
    # the scanner doesn't false-positive on primitive names in text.
    STRIPPED=$(printf '%s' "$LINE" | sed -e 's/"[^"]*"//g' -e "s/'[^']*'//g")

    # Bare numeric or bool token (word boundary).
    if printf '%s' "$STRIPPED" | grep -qE "(^|[^a-zA-Z0-9_])($BARE_NUMS)([^a-zA-Z0-9_]|$)"; then
        deny "arvo has no bare numeric/bool primitives. Line: \`$TRIMMED\`. Use UFixed / IFixed / FastFloat / StrictFloat / USize / Cap / Bool or a domain alias. Escape: \`// lint:allow(no-bare-numeric) reason: ...; tracked: #N\`."
    fi

    # Bare Option / Result tokens. Accept fmt::Result, io::Result.
    if printf '%s' "$STRIPPED" | grep -qE "(^|[^a-zA-Z0-9_])Option([^a-zA-Z0-9_]|$)"; then
        deny "arvo has no bare \`Option\`. Use \`notko::Maybe<T>\`. Line: \`$TRIMMED\`. Escape: \`// lint:allow(no-bare-option) reason: std trait parity; tracked: #N\`."
    fi

    if printf '%s' "$STRIPPED" | grep -qE "(^|[^a-zA-Z0-9_])Result([^a-zA-Z0-9_]|$)"; then
        # fmt::Result / io::Result are allowed.
        if ! printf '%s' "$STRIPPED" | grep -qE "(fmt|io)::Result"; then
            deny "arvo has no bare \`Result\`. Use \`notko::Outcome<T, E>\` (cold) or \`notko::Just<T>\` (hot). Line: \`$TRIMMED\`. Escape: \`// lint:allow(no-bare-result) reason: ...; tracked: #N\`."
        fi
    fi

    # Bare `String` (heap allocated).
    if printf '%s' "$STRIPPED" | grep -qE "(^|[^a-zA-Z0-9_])String([^a-zA-Z0-9_]|$)"; then
        deny "arvo has no bare \`String\` (heap-allocated). Use \`hilavitkutin_str::Str\`. Line: \`$TRIMMED\`."
    fi

    # Non-static `&str`. Allowed forms: `&'static str`, `&mut 'static str`.
    if printf '%s' "$STRIPPED" | grep -qE "(^|[^a-zA-Z0-9_'])&[[:space:]]*(mut[[:space:]]+)?str([^a-zA-Z0-9_]|$)"; then
        deny "arvo has no non-static \`&str\`. Use \`&'static str\` or \`hilavitkutin_str::Str\`. Line: \`$TRIMMED\`."
    fi
done <<< "$CONTENT"

allow
